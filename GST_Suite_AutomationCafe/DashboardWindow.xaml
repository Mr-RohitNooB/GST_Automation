<Window x:Class="GST_Suite_AutomationCafe.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Automation Cafe - Dashboard" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen" Background="#F3F4F6">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#1F2937" Grid.Column="0">
            <StackPanel Margin="20">
                <TextBlock Text="AUTOMATION CAFE" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBlock Text="Commercial RPA Suite" Foreground="#9CA3AF" FontSize="12" Margin="0,0,0,30"/>

                <TextBlock Text="YOUR MODULES" Foreground="#9CA3AF" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <StackPanel x:Name="ModuleContainer">
                    <TextBlock Text="Fetching permissions..." Foreground="White" FontStyle="Italic"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="8" Margin="15">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Welcome to the Suite" FontSize="32" FontWeight="Bold" Foreground="#374151" HorizontalAlignment="Center"/>
                <TextBlock Text="Select an automation module from the sidebar to begin." FontSize="16" Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>